# Kraken API credentials
# Create at https://www.kraken.com/u/security/api
# Recommended permissions:
#   - Query Funds
#   - Query Open Orders & Trades
#   - Query Closed Orders & Trades
#   - Query Ledger Entries
#   - Create & Modify Orders   (only if you plan to trade from this app)
# Do NOT enable "Withdraw Funds".
KRAKEN_API_KEY=your-key-here
KRAKEN_API_SECRET=your-secret-here

# Optional: for the Analyst panel (Claude integration)
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
